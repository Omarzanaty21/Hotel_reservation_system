# ─── Database ─────────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=secret
DB_NAME=HotelReservationDb

# ─── API ──────────────────────────────────────────────────────────────────────
API_PORT=8080

# ─── JWT ──────────────────────────────────────────────────────────────────────
# IMPORTANT: Change this secret before deploying to production!
JWT_SECRET=your-super-secret-key-change-this-in-production-min-32-chars
JWT_ISSUER=HotelReservationAPI
JWT_AUDIENCE=HotelReservationClient
JWT_EXPIRATION_HOURS=24

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_PORT=4200
