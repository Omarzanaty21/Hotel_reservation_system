# Copy this file to .env and adjust values as needed.
# .env is tracked in git with safe defaults so the project works on a clean clone.
# Override any value here when deploying to a real environment.

# ─── Database ─────────────────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=secret
DB_NAME=HotelReservationDb

# ─── API ──────────────────────────────────────────────────────────────────────
API_PORT=8080

# ─── JWT ──────────────────────────────────────────────────────────────────────
# IMPORTANT: Replace this with a strong random secret in any real deployment!
JWT_SECRET=your-super-secret-key-change-this-in-production-min-32-chars
JWT_ISSUER=HotelReservationAPI
JWT_AUDIENCE=HotelReservationClient
JWT_EXPIRATION_HOURS=24

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_PORT=4200
